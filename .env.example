# ============================================================
# 급식 관리 시스템 — 환경변수 템플릿
# 이 파일을 복사해서 .env로 저장 후 실제 값 입력
# .env는 절대 Git에 커밋하지 마세요!
# ============================================================

# Supabase 설정 (https://supabase.com/dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here   # 서버사이드 전용, 클라이언트 노출 금지

# QR 토큰 서명 키 (최소 32자 이상의 무작위 문자열)
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET_KEY=your-random-secret-key-here-minimum-32-chars

# 앱 설정
APP_NAME=급식 관리 시스템
SCHOOL_NAME=○○고등학교
MEAL_TYPE=lunch   # breakfast / lunch / dinner

# 로그 설정
LOG_LEVEL=INFO    # DEBUG / INFO / WARNING / ERROR
